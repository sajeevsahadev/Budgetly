*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
*.iws
*.ipr

# Keystore files — NEVER commit these
*.jks
*.keystore
*.p12

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (not used but just in case)
google-services.json

# Signing secrets
signing.properties

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# npm (not used but safety)
node_modules/

# Room schema exports (commit these for migration tracking)
# app/schemas/  ← intentionally NOT ignored

# Test results
test-results/
