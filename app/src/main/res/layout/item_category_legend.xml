<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="36dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="4dp" android:paddingEnd="4dp" android:layout_marginBottom="4dp">

    <View android:id="@+id/view_legend_color"
        android:layout_width="12dp" android:layout_height="12dp"
        android:background="@drawable/bg_circle" android:layout_marginEnd="10dp"/>

    <TextView android:id="@+id/tv_legend_name"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textSize="13sp"
        android:textColor="@color/text_primary" android:maxLines="1" android:ellipsize="end"/>

    <TextView android:id="@+id/tv_legend_percent"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="@color/text_secondary"
        android:layout_marginEnd="12dp"/>

    <TextView android:id="@+id/tv_legend_amount"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_primary"/>

</LinearLayout>
