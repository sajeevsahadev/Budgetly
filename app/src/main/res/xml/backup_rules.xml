<?xml version="1.0" encoding="utf-8"?>
<!-- No cloud backup: all data is private and stays on-device -->
<full-backup-content>
    <exclude domain="database" path="."/>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="file" path="."/>
    <exclude domain="root" path="."/>
</full-backup-content>
